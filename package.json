{
  "name": "onzip",
  "version": "0.1.0",
  "description": "온집 — 우리 집 생활을 한곳에",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "env:check": "node scripts/env-check.mjs",
    "analytics:check": "node scripts/analytics-privacy-check.mjs",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-check.mjs",
    "smoke:prod": "node scripts/prod-smoke-check.mjs",
    "verify": "npm run env:check && npm run analytics:check && npm run typecheck && npm run build && npm run smoke",
    "release:check": "node scripts/release-check.mjs",
    "deploy:prod": "vercel --prod --yes",
    "release:prod": "npm run verify && npm run release:check && npm run deploy:prod && npm run smoke:prod"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "canvas": "^3.2.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
